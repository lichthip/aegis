# ── Python / Backend ──────────────────────────────────────────────────────────
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/.env
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# ── Node / Frontend ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# ── Environment files (NEVER commit real keys) ────────────────────────────────
.env
.env.local
.env.production
