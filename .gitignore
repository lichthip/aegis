!backend/.env.example

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
.cache/